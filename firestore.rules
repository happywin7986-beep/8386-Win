rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate IDs to prevent ID Poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Products collection rules
    match /products/{productId} {
      allow read: if true; // Public catalog access
      allow write: if true; // Admin modifies products
    }

    // 3. Categories collection rules
    match /categories/{categoryId} {
      allow read: if true; // Public catalog filters
      allow write: if true; // Admin modifies categories
    }

    // 4. Users collection rules
    match /users/{username} {
      allow read, write: if isValidId(username); // Allow registration, login profile modification
    }

    // 5. Payment requests collection rules
    match /paymentRequests/{paymentRequestId} {
      allow read, write: if isValidId(paymentRequestId); // Allow creation and admin approvals
    }
  }
}
